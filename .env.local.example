# Sanity — fill in after running `npx sanity init` inside /sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-12-01

# Server-only: token with "Editor" role so the import script can write
SANITY_API_WRITE_TOKEN=

# Optional: read token for draft/preview content
SANITY_API_READ_TOKEN=

# Used by revalidation webhook
SANITY_REVALIDATE_SECRET=
